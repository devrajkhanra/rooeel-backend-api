generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────────────────────────

model Admin {
  id           Int            @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String         @unique
  password     String
  createdAt    DateTime       @default(now())
  users        User[]
  requests     UserRequest[]
  projects     Project[]
  workOrders   WorkOrderPdf[]
}

// ─────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────

model User {
  id            Int           @id @default(autoincrement())
  firstName     String
  lastName      String
  email         String        @unique
  password      String
  createdAt     DateTime      @default(now())
  createdBy     Int?
  admin         Admin?        @relation(fields: [createdBy], references: [id])
  requests      UserRequest[]
  projects      ProjectUser[]
  assignedTasks Task[]
  subtasks      SubTask[]
}

// ─────────────────────────────────────────────────────────────
// AUTH / TOKENS
// ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  userType  String    // 'admin' | 'user'
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([userType])
  @@index([token])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────
// USER REQUESTS (change requests)
// ─────────────────────────────────────────────────────────────

model UserRequest {
  id             Int      @id @default(autoincrement())
  userId         Int
  adminId        Int
  requestType    String   // 'firstName' | 'lastName' | 'email' | 'password'
  currentValue   String?
  requestedValue String?
  status         String   @default("pending") // 'pending' | 'approved' | 'rejected'
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin          Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([adminId])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// PROJECT
// ─────────────────────────────────────────────────────────────

model Project {
  id           Int                @id @default(autoincrement())
  name         String
  description  String?
  image        String?
  status       String             @default("active") // 'active' | 'inactive' | 'completed'
  createdBy    Int
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  admin        Admin              @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  users        ProjectUser[]
  tasks        Task[]
  fields       ProjectField[]
  fieldValues  ProjectFieldValue[]
  workOrders   WorkOrderPdf[]     // Multiple PDFs per project (versioned)
  departments  Department[]
  roles        ProjectRole[]

  @@index([createdBy])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────
// WORK ORDER PDFs (versioned list per project)
// ─────────────────────────────────────────────────────────────

model WorkOrderPdf {
  id          Int      @id @default(autoincrement())
  projectId   Int
  fileKey     String   // S3 / MinIO key (e.g. "work-orders/uuid.pdf")
  fileName    String   // Original filename for display
  uploadedBy  Int      // Admin ID who uploaded
  createdAt   DateTime @default(now())

  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  admin       Admin    @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([uploadedBy])
}

// ─────────────────────────────────────────────────────────────
// DYNAMIC PROJECT FIELDS
// ─────────────────────────────────────────────────────────────

model ProjectField {
  id          Int                 @id @default(autoincrement())
  projectId   Int
  name        String              // Machine name (e.g. "clientName")
  label       String              // Display label (e.g. "Client Name")
  fieldType   String              // 'text' | 'number' | 'date' | 'select' | 'textarea' | 'file'
  options     Json?               // For 'select': [{ value, label }]
  required    Boolean             @default(false)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  value       ProjectFieldValue?

  @@index([projectId])
}

model ProjectFieldValue {
  id        Int          @id @default(autoincrement())
  fieldId   Int
  projectId Int
  value     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  field     ProjectField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([fieldId])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENTS (per project)
// ─────────────────────────────────────────────────────────────

model Department {
  id          Int           @id @default(autoincrement())
  projectId   Int
  name        String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users       ProjectUser[]
  tasks       Task[]
  permissions Permission[]

  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────
// DYNAMIC ROLES (per project)
// ─────────────────────────────────────────────────────────────

model ProjectRole {
  id          Int           @id @default(autoincrement())
  projectId   Int
  name        String        // e.g. "Site Engineer", "Foreman"
  createdAt   DateTime      @default(now())

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  users       ProjectUser[]
  permissions Permission[]

  @@unique([projectId, name])
  @@index([projectId])
}

// ─────────────────────────────────────────────────────────────
// PERMISSIONS  (role × department × resource × CRUD)
// ─────────────────────────────────────────────────────────────

model Permission {
  id            Int          @id @default(autoincrement())
  projectRoleId Int
  departmentId  Int?         // null = project-level permission
  resource      String       // 'WORK_ORDER' | 'TASK' | 'SUBTASK' | 'DEPARTMENT' | 'USER'
  canView       Boolean      @default(false)
  canCreate     Boolean      @default(false)
  canEdit       Boolean      @default(false)
  canDelete     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  projectRole   ProjectRole  @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)
  department    Department?  @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([projectRoleId, departmentId, resource])
  @@index([projectRoleId])
  @@index([departmentId])
}

// ─────────────────────────────────────────────────────────────
// PROJECT MEMBERS  (user ↔ project join, with role + department)
// ─────────────────────────────────────────────────────────────

model ProjectUser {
  id            Int          @id @default(autoincrement())
  projectId     Int
  userId        Int
  projectRoleId Int?         // FK to ProjectRole (dynamic, nullable)
  departmentId  Int?         // FK to Department (nullable)
  assignedAt    DateTime     @default(now())

  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole   ProjectRole? @relation(fields: [projectRoleId], references: [id], onDelete: SetNull)
  department    Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([projectRoleId])
  @@index([departmentId])
}

// ─────────────────────────────────────────────────────────────
// TASKS
// ─────────────────────────────────────────────────────────────

model Task {
  id             Int       @id @default(autoincrement())
  projectId      Int
  departmentId   Int?      // Optional — task can be dept-scoped
  title          String
  description    String?
  status         String    @default("pending") // 'pending' | 'in-progress' | 'done'
  type           String    @default("basic")   // 'basic' | 'form'
  formSchema     Json?     // Dynamic form definition
  submissionData Json?     // User submission data
  assignedTo     Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignee       User?      @relation(fields: [assignedTo], references: [id], onDelete: SetNull)
  subtasks       SubTask[]

  @@index([projectId])
  @@index([departmentId])
  @@index([assignedTo])
}

// ─────────────────────────────────────────────────────────────
// SUBTASKS
// ─────────────────────────────────────────────────────────────

model SubTask {
  id             Int      @id @default(autoincrement())
  taskId         Int
  title          String
  description    String?
  status         String   @default("pending")
  type           String   @default("basic")
  formSchema     Json?
  submissionData Json?
  assignedTo     Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee       User?    @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([assignedTo])
}
